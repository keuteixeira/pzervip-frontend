NUXT_PUBLIC_API_BASE=http://localhost:8000/api

# URL pública do site (sem barra final) — canonical, Open Graph e Twitter
# NUXT_PUBLIC_SITE_URL=https://seudominio.com

# Google Analytics 4 (gtag) — opcional; vazio desativa o snippet Nuxt e liga o plugin
# ga-datalayer-bridge (espelho dataLayer → gtag para eventos de PIX, se o GTM injetar gtag).
# NUXT_PUBLIC_GA_MEASUREMENT_ID=G-ZMC51VP8LH

# Credenciais padrão do seed demo (DemoAdvertiserSeeder no Laravel) — só para dev
# DEMO_ADVERTISER_EMAIL=demo@prazervip.local
# DEMO_ADVERTISER_PASSWORD=demo123456
